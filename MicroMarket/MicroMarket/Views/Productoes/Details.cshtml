@model MicroMarket.Models.Producto

@{
    ViewData["Title"] = "Details";
}

<h1>Detalles de Producto</h1>

<div>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Precio)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Precio)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Descripcion)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Descripcion)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Stock)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Stock)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StockMinimo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StockMinimo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.StockMaximo)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.StockMaximo)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.TipoProducto)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.TipoProducto)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FechaVencimiento)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FechaVencimiento)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.UrlFoto)
        </dt>
        <dd class="col-sm-10">
            @if (!string.IsNullOrEmpty(Model.UrlFoto))
            {
                <img src="@Model.UrlFoto" alt="Foto del producto" style="max-width:250px;max-height:250px;object-fit:cover;" />
            }
            else
            {
                <span>Sin foto</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ProductoId" class="btn btn-success shadow-sm">Editar</a> |
    <a asp-action="Index" class="btn btn-success shadow-sm">Volver</a>
</div>
